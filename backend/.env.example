# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/dbname
#DATABASE_URL=postgresql://your_user:your_password@your_third_party_host:5432/your_db_name
# Gemini API Key (Required for Voice, Vision, and Agentic features)

DATABASE_URL=postgresql://your_user:your_password@your_host:6543/your_db_name
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Configuration for Landlord Emails
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password
